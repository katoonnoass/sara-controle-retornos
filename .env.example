# SARA - Configuracao de ambiente
# Copie este arquivo como .env e ajuste os valores

# Ambiente: development, homologation, ou production
APP_ENV=homologation

# Flask debug (true apenas em desenvolvimento)
FLASK_DEBUG=false

# Host e porta do servidor
HOST=0.0.0.0
PORT=5000

# URL de conexao com PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:senha@localhost:5432/sara

# Chave secreta para assinatura de sessao
# Gere uma nova com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=troque-esta-chave-em-producao
