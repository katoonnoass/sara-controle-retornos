<Window x:Class="SaraServerAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SARA Server Agent"
        Width="640" Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#1A1D23"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="SARA Server Agent" FontSize="22" FontWeight="Bold" Foreground="#E8ECF1" Margin="0,0,0,12"/>

        <!-- Status -->
        <Border Grid.Row="1" BorderBrush="#333842" BorderThickness="1" CornerRadius="8" Padding="14" Background="#22262E" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="StatusText" Text="Server: Stopped" FontSize="16" FontWeight="SemiBold" Foreground="#9CA3AF"/>
                <TextBlock x:Name="UrlText" Text="URL: http://127.0.0.1:5000" FontSize="11" Foreground="#6B7280" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2">
            <Button x:Name="BtnStart" Content="  Start" Height="34" Margin="0,0,0,6" Cursor="Hand" Background="#166534" Foreground="White" BorderThickness="0" Click="BtnStart_Click"/>
            <Button x:Name="BtnStop" Content="  Stop" Height="34" Margin="0,0,0,6" Cursor="Hand" Background="#7F1D1D" Foreground="White" BorderThickness="0" Click="BtnStop_Click" IsEnabled="False"/>
            <Button x:Name="BtnOpen" Content="  Open SARA" Height="34" Cursor="Hand" Background="#2A2F38" Foreground="#E8ECF1" BorderThickness="1" BorderBrush="#333842" Click="BtnOpen_Click"/>
        </StackPanel>
    </Grid>
</Window>
