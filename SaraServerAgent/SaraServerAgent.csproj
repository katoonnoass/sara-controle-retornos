<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>

    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>SARA Server Agent</AssemblyName>
    <RootNamespace>SaraServerAgent</RootNamespace>
    <Title>SARA Server Agent</Title>
    <Description>Windows Agent for controlling the SARA web server</Description>
    <Company>Ephar</Company>
    <Product>SARA Server Agent</Product>
    <Version>1.0.0.0</Version>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="System.Drawing.Common" Version="8.0.0" />
  </ItemGroup>



</Project>
